@using WebApplication_MVCNia.Models.Entities;
@model List<School>
@{
    ViewData["Title"] = "Schools Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to the Schools Page</h1>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Director</th>
                <th>FoundationDate</th>
                <th>StudentsQuantity</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (School school in Model)
            {
                <tr>
                    <td>@school.Id</td>
                    <td>@school.Name</td>
                    <td>@school.Director</td>
                    <td>@school.FoundationDate</td>
                    <td>@school.StudentsQuantity</td>
                    <td>
                        <a class="text-dark" asp-area="View" asp-action="View" asp-route-id="@school.Id">
                            <i class="fa-regular fa-eye"></i>
                        </a>
                        <a class="text-dark" asp-area="Edit" asp-action="Edit" asp-route-id="@school.Id">
                            <i class="fa-regular fa-pen-to-square"></i>
                        </a>
                        <a class="text-dark" asp-area="Delete" asp-action="Delete" asp-route-id="@school.Id">
                            <i class="fa-solid fa-x"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
